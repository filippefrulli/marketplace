# ── Database ──────────────────────────────────────────────────────────────────
# Supabase → Settings → Database → Connection string → URI (use direct, port 5432 — not the pooler)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# ── Supabase ──────────────────────────────────────────────────────────────────
# Supabase → Settings → API Keys
#
# Project URL (same as before)
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
#
# Publishable key — replaces the legacy "anon" key. Format: sb_publishable_...
# Safe to expose in the browser. Enforces Row Level Security.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
#
# Secret key — replaces the legacy "service_role" key. Format: sb_secret_...
# Server-only. Bypasses RLS. Never expose to the client.
SUPABASE_SECRET_KEY="sb_secret_..."

# ── Stripe ────────────────────────────────────────────────────────────────────
# Stripe Dashboard → Developers → API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
# Run: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── Search (optional — skip for initial MVP) ──────────────────────────────────
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_ADMIN_KEY=""

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
